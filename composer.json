{
    "name": "silverengine/framework",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "SilverEngine",
            "email": "support@silverengine.net"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "Packages/silverengine/error-handler"
        }
    ],
    "require": {
        "php": ">=8.1",
        "silverengine/error-handler": "@dev"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/",
            "Silver\\": "System/",
            "Database\\": "Database/"
        }
    },
    "autoload-dev": {
        "psr-4": {}
    },
    "require-dev": {
        "phpunit/phpunit": "^5"
    }
}
