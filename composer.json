{
    "name": "silverengine/framework",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "SilverEngine",
            "email": "support@silverengine.net"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "Packages/silverengine/error-handler"
        },
        {
            "type": "path",
            "url": "Packages/silverengine/core"
        }
    ],
    "require": {
        "php": ">=8.4",
        "silverengine/core": "@dev",
        "silverengine/error-handler": "@dev",
        "nejcc/php-datatypes": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App/",
            "Database\\": "Database/",
            "System\\App\\": "Packages/silverengine/core/src/App/"
        }
    },
    "autoload-dev": {
        "psr-4": {}
    },
    "require-dev": {}
}
